    "compliance_standard": "ASA-CSSA-SSSA"
  },

  "approval_gates": [
    {
      "gate_id": "gate-001",
      "gate_name": "Lead Agronomist Verification",
      "gate_type": "technical_review",
      "priority": 1,
      "required": true,
      "blocking": true,
      "description": "Mandatory technical verification of soil analysis methodology, data interpretation, and agricultural conclusions by qualified Lead Agronomist",
      
      "approver_role": {
        "title": "Lead Agronomist",
        "required_credentials": [
          "Certified Crop Adviser (CCA)",
          "M.S. or Ph.D. in Agronomy, Soil Science, or related field",
          "Minimum 5 years experience in organic agricultural systems"
        ],
        "department": "Agricultural Research & Development",
        "authority_level": "technical_sign_off"
      },
      
      "review_criteria": [
        {
          "criterion_id": "TC-001",
          "criterion": "Methodology Validation",
          "description": "Verify soil sampling protocol, laboratory analysis methods, and statistical approaches meet scientific standards",
          "required": true
        },
        {
          "criterion_id": "TC-002",
          "criterion": "Data Accuracy",
          "description": "Confirm nitrogen concentration values, statistical calculations, and compliance analysis are accurate and reproducible",
          "required": true
        },
        {
          "criterion_id": "TC-003",
          "criterion": "Interpretation Validity",
          "description": "Assess whether conclusions drawn from data are scientifically supported and appropriately qualified",
          "required": true
        },
        {
          "criterion_id": "TC-004",
          "criterion": "Compliance Verification",
          "description": "Verify manuscript adheres to ASA-CSSA-SSSA agricultural reporting standards",
          "required": true
        },
        {
          "criterion_id": "TC-005",
          "criterion": "Visualization Review",
          "description": "Approve accuracy and clarity of figures, tables, and data visualizations",
          "required": true
        }
      ],
      
      "approval_actions": {
        "approve": {
          "action": "proceed_to_next_gate",
          "requires_signature": true,
          "requires_date": true,
          "requires_comments": false
        },
        "approve_with_conditions": {
          "action": "conditional_approval",
          "requires_signature": true,
          "requires_date": true,
          "requires_comments": true,
          "condition_resolution_required": true
        },
        "reject": {
          "action": "return_for_revision",
          "requires_signature": true,
          "requires_date": true,
          "requires_comments": true,
          "revision_tracking": true
        }
      },
      
      "sla": {
        "review_period_days": 5,
        "escalation_after_days": 7,
        "escalation_contact": "Research Program Director"
      }
    },
    
    {
      "gate_id": "gate-002",
      "gate_name": "Research Director Authorization",
      "gate_type": "administrative_approval",
      "priority": 2,
      "required": true,
      "blocking": true,
      "description": "Final administrative authorization for publication release",
      "depends_on": ["gate-001"],
      
      "approver_role": {
        "title": "Research Program Director",
        "department": "Agricultural Research & Development",
        "authority_level": "publication_authorization"
      },
      
      "review_criteria": [
        {
          "criterion_id": "AC-001",
          "criterion": "Gate 1 Completion",
          "description": "Confirm Lead Agronomist approval has been obtained",
          "required": true
        },
        {
          "criterion_id": "AC-002",
          "criterion": "Publication Readiness",
          "description": "Verify manuscript is complete and ready for external distribution",
          "required": true
        },
        {
          "criterion_id": "AC-003",
          "criterion": "Stakeholder Review",
          "description": "Confirm relevant stakeholders have been consulted",
          "required": false
        }
      ],
      
      "approval_actions": {
        "approve": {
          "action": "authorize_publication",
          "requires_signature": true,
          "requires_date": true
        },
        "reject": {
          "action": "return_for_revision",
          "requires_signature": true,
          "requires_date": true,
          "requires_comments": true
        }
      },
      
      "sla": {
        "review_period_days": 3,
        "escalation_after_days": 5,
        "escalation_contact": "Executive Director"
      }
    }
  ],

